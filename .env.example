# ============================================
# CRYPTO AI INSIGHT PLATFORM - ENV EXAMPLE
# ============================================
# Copy this file to .env.local and fill in values

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="CryptoAI Insights"

# --- Backend API ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# --- Auth ---
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- Points ---
NEXT_PUBLIC_POINTS_PER_QUERY=10
NEXT_PUBLIC_FREE_SIGNUP_POINTS=50
NEXT_PUBLIC_POINTS_PRICE_USD=5
NEXT_PUBLIC_POINTS_BUNDLE_SIZE=50

# --- Polling ---
NEXT_PUBLIC_POLL_INTERVAL_MS=2000
NEXT_PUBLIC_POLL_MAX_ATTEMPTS=60
